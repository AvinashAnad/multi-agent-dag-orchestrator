# ── Secrets & local config ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python virtual environments ───────────────────────────────────────────────
.venv/
venv/
env/
__pypackages__/

# ── Python cache & build artefacts ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── uv / pip lock ────────────────────────────────────────────────────────────
